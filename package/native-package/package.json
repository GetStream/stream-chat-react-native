    "@react-native-clipboard/clipboard": ">=1.16.0",
    "@react-native-documents/picker": ">=10.1.1",
    "react-native": ">=0.76.0",
    "react-native-audio-recorder-player": ">=3.6.13",
    "react-native-nitro-sound": ">=0.2.9",
    "react-native-blob-util": ">=0.22.0",
