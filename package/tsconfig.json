{
  "extends": "@stream-io/typescript-config/library.json",
  "compilerOptions": {
    "rootDir": "./src"
  },
  "include": ["./src/**/*"],
  "exclude": [
    "./src/components/docs/*",
    "./src/emoji-data/*.js",
    "./src/mock-builders",
    "./src/styleguideComponents",
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "**/__tests__",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
