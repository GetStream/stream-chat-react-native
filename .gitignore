examples/SampleApp/fastlane/fastlane.log
examples/SampleApp/fastlane/report.xml
examples/SampleApp/fastlane/metrics/
examples/SampleApp/tmp/
index.android.bundle
*.app
*.DSYM.zip
**/metrics/
package/shared-native/.sync-state/

.claude/worktrees
